{
  "manifest_version": 3,
  "name": "PageChat",
  "short_name": "PageChat",
  "version": "0.2.0",
  "description": "Chat with any webpage. Local LLM + RAG — zero data sent to any server.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PageChat",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [{
    "resources": [
      "sidepanel/index.html",
      "sidepanel/app.js",
      "sidepanel/styles.css",
      "sidepanel/vendor/react.js",
      "sidepanel/vendor/react-dom.js",
      "lib/wllama.js",
      "lib/wllama.wasm",
      "lib/wllama-bridge.js"
    ],
    "matches": ["<all_urls>"]
  }],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
